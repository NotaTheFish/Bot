BOT_TOKEN=123456:AA...
DATABASE_URL=postgresql://user:pass@host:5432/db
SUPER_ADMINS=123456789
# Админы, которые могут ТОЛЬКО принимать заявки на вывод (ни банов, ни настроек).
# Через запятую. Оставь пустым, если не нужно.
PAYOUT_ADMINS=
# Промокод для теста вывода: /promo КОД начислит 100k грибов или 2M коинов.
# Пусто — промокода нет. Удалишь переменную — перестанет работать.
PROMO_CODE=

# Необязательно: чат, чей владелец обрабатывает выводы. Пусто — самый ранний активный.
PAYOUT_CHAT_ID=

# Рулетка !шайн работает ТОЛЬКО в чатах, включённых через /шимм (главный админ).
# ROULETTE_DAILY_BUDGET — общий суточный потолок-предохранитель в грибах на все
# одобренные чаты вместе. По умолчанию 300000.
ROULETTE_DAILY_BUDGET=300000

# ТОЛЬКО ДЛЯ ТЕСТА: безлимитная рулетка этим ID. Очистить перед боевым запуском!
UNLIMITED_SPIN_IDS=

# --- Еженедельный конкурс по активности (/шимшайнуть) ---
CONTEST_TZ=Europe/Moscow
CONTEST_MIN_MSGS=500
CONTEST_MSGS_PER_TICKET=50
# Привязали чат в середине недели: 1 — считать текущую неполную неделю,
# 0 — пропустить, первый конкурс со следующего понедельника (по умолчанию).
CONTEST_COUNT_PARTIAL_FIRST=0
# ТЕСТ: >0 — «неделя» длится столько минут. 0 = настоящая неделя. Очистить перед боем!
CONTEST_TEST_MINUTES=0
