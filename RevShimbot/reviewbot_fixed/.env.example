BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql://user:password@host:5432/dbname
BOT_USERNAME=your_bot_username_without_@

# Приватный канал/чат где бот является администратором.
# Используется для кеширования карточек при inline-отзывах.
# Как получить ID: добавь бота в канал как админа,
# перешли любое сообщение из канала боту @username_to_id_bot — он покажет ID.
# ID канала обычно начинается с -100, например: -1001234567890
CACHE_CHAT_ID=-1001234567890
